# Database Configuration
# Leave empty to use SQLite: sqlite:///./travel_dashboard.db
DATABASE_URL=

# OpenAI Configuration
OPENAI_API_KEY=

# Google OAuth Configuration
# Required for real Gmail scanning. If empty, the app will run in Demo/Simulation mode.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
